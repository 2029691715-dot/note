{
  "name": "notes-app",
  "version": "1.0.0",
  "description": "A modern note-taking app with bidirectional links, block references, and tags",
  "author": "Notes App",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "electron:dev": "concurrently \"vite\" \"electron .\"",
    "electron:build": "vite build && electron-builder"
  },
  "dependencies": {
    "@tiptap/extension-code-block": "^2.2.0",
    "@tiptap/extension-highlight": "^2.2.0",
    "@tiptap/extension-image": "^2.2.0",
    "@tiptap/extension-link": "^2.2.0",
    "@tiptap/extension-placeholder": "^2.2.0",
    "@tiptap/extension-table": "^2.2.0",
    "@tiptap/extension-table-cell": "^2.2.0",
    "@tiptap/extension-table-header": "^2.2.0",
    "@tiptap/extension-table-row": "^2.2.0",
    "@tiptap/extension-task-item": "^2.2.0",
    "@tiptap/extension-task-list": "^2.2.0",
    "@tiptap/starter-kit": "^2.2.0",
    "@tiptap/vue-3": "^2.2.0",
    "jszip": "^3.10.1",
    "pinia": "^2.1.0",
    "uuid": "^9.0.0",
    "vue": "^3.4.0",
    "vue-router": "^4.2.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "@vitejs/plugin-vue": "^5.0.0",
    "concurrently": "^9.2.1",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2",
    "vite": "^5.0.0"
  },
  "build": {
    "appId": "com.notes.app",
    "productName": "Notes",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "npmRebuild": false,
    "asar": true,
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}
